{
    "version": 2,
    "builds": [
        {
            "src": "packages/backend/dist/main.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/packages/backend/(.*)",
            "dest": "packages/backend/dist/main.js",
            "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
        }
    ]
}